# Rebuild QCOW2 virtual machine disk image (builds container image first)
def "nur rebuild-qcow2" [target_image?: string, tag?: string] {
    let config = (get-config)
    let img_base = ($target_image | default $config.image_name)
    let t = ($tag | default $config.default_tag)
    
    nur build $img_base $t
    let img_full = if ($img_base | str starts-with "localhost/") { $img_base } else { $"localhost/($img_base)" }
    nur build-qcow2 $img_full $t
}

