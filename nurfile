def run-vm [target_image: string, tag: string, type: string] {
    let image_file = if $type == "iso" {
        "output/bootiso/install.iso"
    } else {
        $"output/($type)/disk.($type)"
    }
    
    if not ($image_file | path exists) {
        error make {msg: $"Image file ($image_file) does not exist. Please build it first."}
    }
    
    mut port = 8006
    loop {
        let check = (try { ^ss -tunalp | grep $":($port)" } catch { "" })
        if ($check | is-empty) {
            break
        }
        $port = $port + 1
    }
    
    print $"Using Port: ($port)"
    print $"Connect to http://localhost:($port)"
    
    bash -c $"sleep 10 && xdg-open http://localhost:($port) &"
    
    ^podman run --rm --privileged --pull=newer $"--publish=127.0.0.1:($port):8006" --env "CPU_CORES=4" --env "RAM_SIZE=8G" --env "DISK_SIZE=64G" --env "TPM=Y" --env "GPU=Y" --device=/dev/kvm $"--volume=($env.PWD)/($image_file):/boot.($type)" docker.io/qemux/qemu
}

