# nurfile — task runner based on Nushell
# Env vars are injected by mise (see mise.toml [env] section).
# Override locally via .env (gitignored) or by exporting env vars.

def get-config [] {
    {
        image_name: ($env.IMAGE_NAME? | default "dromaeosaurus")
        repo_org: ($env.REPO_ORGANIZATION? | default "rjallais")
        image_desc: ($env.IMAGE_DESC? | default "Custom Bluefin workstation with xonedo Xbox dongle driver and developer utilities")
        image_keywords: ($env.IMAGE_KEYWORDS? | default "bootc,ublue,universal-blue")
        image_logo_url: ($env.IMAGE_LOGO_URL? | default "https://avatars.githubusercontent.com/u/120078124?s=200&v=4")
        default_tag: ($env.DEFAULT_TAG? | default "testing")
        bib_image: ($env.BIB_IMAGE? | default "quay.io/centos-bootc/bootc-image-builder:latest")
    }
}

# Clean build artifacts and outputs
def "nur clean" [] {
    print "Cleaning build files..."
    rm -rf _build* output previous.manifest.json changelog.md output.env
}

# Remove build artifacts and outputs using sudo privileges
def "nur sudo-clean" [] {
    print "Cleaning build files with sudo..."
    if (which sudo | is-empty) {
        rm -rf _build* output previous.manifest.json changelog.md output.env
    } else {
        ^sudo rm -rf _build* output previous.manifest.json changelog.md output.env
    }
}

# Build the container image using Podman
def "nur build" [
    target_image?: string, # Target image name (defaults to IMAGE_NAME)
    tag?: string          # Tag for the image (defaults to DEFAULT_TAG)
] {
    let config = (get-config)
    let img = ($target_image | default $config.image_name)
    let t = ($tag | default $config.default_tag)
    
    let git_clean = ((sys | get host | name) != "windows" and (do -i { git status -s } | is-empty))
    
    mut labels = []
    if $git_clean {
        let git_sha = (git rev-parse --short HEAD | str trim)
        let repo = $"($config.repo_org)/($config.image_name)"
        $labels = ($labels | append [
            "--label" $"io.artifacthub.package.readme-url=https://raw.githubusercontent.com/($repo)/($git_sha)/README.md"
            "--label" $"org.opencontainers.image.documentation=https://raw.githubusercontent.com/($repo)/($git_sha)/README.md"
            "--label" $"org.opencontainers.image.source=https://github.com/($repo)/blob/($git_sha)/Containerfile"
            "--label" $"org.opencontainers.image.url=https://github.com/($repo)/tree/($git_sha)"
            "--label" $"org.opencontainers.image.version=($t).(date | format date "%Y%m%d")-($git_sha)"
        ])
    }
    
    let date_str = (date now | format date "%Y-%m-%dT%H:%M:%SZ")
    $labels = ($labels | append [
        "--label" "io.artifacthub.package.deprecated=false"
        "--label" $"io.artifacthub.package.keywords=($config.image_keywords)"
        "--label" "io.artifacthub.package.license=Apache-2.0"
        "--label" $"io.artifacthub.package.logo-url=($config.image_logo_url)"
        "--label" "io.artifacthub.package.prerelease=false"
        "--label" $"org.opencontainers.image.created=($date_str)"
        "--label" $"org.opencontainers.image.description=($config.image_desc)"
        "--label" $"org.opencontainers.image.title=($img)"
        "--label" $"org.opencontainers.image.vendor=($config.repo_org)"
    ])
    
    let args = [
        "build"
        ...$labels
        "--pull=newer"
        "--tag" $"($img):($t)"
        "--file" "Containerfile"
        "."
    ]
    
    print $"Running: podman ($args | str join ' ')"
    ^podman ...$args
}

# Split the image for smaller updates (Chunkah)
def "nur rechunk" [
    target_image?: string,
    tag?: string
] {
    let config = (get-config)
    let img = ($target_image | default $config.image_name)
    let t = ($tag | default $config.default_tag)
    
    let config_str = (podman inspect $img)
    
    ^podman run --rm $"--mount=type=image,src=($img),target=/chunkah" -e $"CHUNKAH_CONFIG_STR=($config_str)" quay.io/coreos/chunkah:latest build --verbose --compressed --max-layers 128 --prune /sysroot/ --label ostree.commit- --label ostree.final-diffid- --tag $"($img):($t)"
}

def rootful-load-image [target_image: string, tag: string] {
    let uid = (id -u | str trim | into int)
    if $uid == 0 {
        return
    }
    
    let has_root_img = (try {
        sudo podman inspect $target_image | is-not-empty
    } catch {
        false
    })
    
    if not $has_root_img {
        print $"Loading ($target_image):($tag) to rootful podman storage..."
        let tmpdir = (mktemp -d -p $env.PWD)
        sudo env $"TMPDIR=($tmpdir)" podman image scp $"($uid)@localhost::($target_image):($tag)" $"root@localhost::($target_image):($tag)"
        rm -rf $tmpdir
    }
}

def build-bib [target_image: string, tag: string, type: string, config_file: string] {
    rootful-load-image $target_image $tag
    
    let build_tmp = (mktemp -d -p $env.PWD)
    let config = (get-config)
    
    print $"Running bootc-image-builder for ($type)..."
    sudo podman run --rm -it --privileged --pull=newer --net=host --security-opt label=type:unconfined_t $"--volume=($env.PWD)/($config_file):/config.toml:ro" $"--volume=($build_tmp):/output" --volume=/var/lib/containers/storage:/var/lib/containers/storage $config.bib_image --type $type --use-librepo=True --rootfs=btrfs $"($target_image):($tag)"
    
    mkdir output
    sudo mv -f $"($build_tmp)/*" output/
    sudo rmdir $build_tmp
    let user_name = (id -un | str trim)
    sudo chown -R $"($user_name):($user_name)" output/
}

