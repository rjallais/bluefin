# Spawn VM via systemd-vmspawn
def "nur spawn-vm" [
    --rebuild,
    --type: string = "qcow2",
    --ram: string = "6G"
] {
    let config = (get-config)
    if $rebuild {
        build-bib $"localhost/($config.image_name)" $config.default_tag $type "iso/disk.toml"
    }
    
    let ram_bytes = (do -i { ^numfmt --from=iec $ram | str trim | into int } | default 6442450944)
    
    ^systemd-vmspawn -M "bootc-image" --console=gui --cpus=2 $"--ram=($ram_bytes)" --network-user-mode --vsock=false --pass-ssh-key=false -i (glob $"./output/*/*.($type)" | first)
}

# Check nurfile syntax and shell scripts
def "nur check" [] {
    print "Checking nurfile syntax..."
    nu --ide-check 10 nurfile
    print "Nurfile OK"
}

# Format scripts using shfmt
def "nur format" [] {
    if (which shfmt | is-empty) {
        print "shfmt not found. Skipping format."
    } else {
        ^find . -iname "*.sh" -type f -exec shfmt --write "{}" ";"
    }
}

# Lint scripts using shellcheck
def "nur lint" [] {
    if (which shellcheck | is-empty) {
        print "shellcheck not found. Skipping lint."
    } else {
        ^find . -iname "*.sh" -type f -exec shellcheck "{}" ";"
    }
}

# Push image to GHCR (secrets injected by fnox)
def "nur push" [
    target_image?: string,
    tag?: string
] {
    let config = (get-config)
    let img = ($target_image | default $config.image_name)
    let t = ($tag | default $config.default_tag)
    let registry = $"ghcr.io/($config.repo_org)"
    let token = ($env.GHCR_TOKEN? | default "")

    if ($token | is-empty) {
        error make {msg: "GHCR_TOKEN not set. Run: fnox set GHCR_TOKEN <your-token>"}
    }

    print $"Logging in to ($registry)..."
    $token | ^podman login ghcr.io -u $config.repo_org --password-stdin

    print $"Pushing ($registry)/($img):($t)..."
    ^podman push $"($img):($t)" $"($registry)/($img):($t)"
}

# Sign image with cosign keyless OIDC (secrets injected by fnox)
def "nur sign" [
    target_image?: string,
    tag?: string
] {
    let config = (get-config)
    let img = ($target_image | default $config.image_name)
    let t = ($tag | default $config.default_tag)
    let registry = $"ghcr.io/($config.repo_org)"
    let full_ref = $"($registry)/($img):($t)"

    if (which cosign | is-empty) {
        error make {msg: "cosign not found. Install it: mise use -g cosign"}
    }

    print $"Signing ($full_ref)..."
    ^cosign sign -y $full_ref
}

# Tag local container images with alias tags
def "nur tag-images" [image_name: string, default_tag: string, tags: string] {
    if ($image_name | is-empty) or ($default_tag | is-empty) or ($tags | is-empty) {
        error make {msg: "Usage: nur tag-images <image_name> <default_tag> <tags>"}
    }
    let img_id = (podman inspect $"localhost/($image_name):($default_tag)" | from json | get 0.Id)
    do -i { ^podman untag $"localhost/($image_name):($default_tag)" }
    for tag in ($tags | split row " " | filter { |t| $t | is-not-empty }) {
        ^podman tag $img_id $"($image_name):($tag)"
    }
    ^podman tag $img_id $"localhost/($image_name):($default_tag)"
    print $"Tagged ($image_name) with: ($tags)"
}
